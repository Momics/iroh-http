{
  "private": true,
  "workspaces": [
    "packages/iroh-http-shared",
    "packages/iroh-http-node",
    "packages/iroh-http-tauri"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces",
    "build:core":   "bash scripts/build-core.sh",
    "build:ts":     "bash scripts/build-ts.sh",
    "build:node":   "bash scripts/build-node.sh",
    "build:tauri":  "bash scripts/build-tauri.sh",
    "build:deno":   "bash scripts/build-deno.sh",
    "build": "npm run build:core && npm run build:ts && npm run build:node && npm run build:tauri && npm run build:deno",
    "test:rust": "cargo test --workspace",
    "test:node": "npm test --workspace=packages/iroh-http-node",
    "test:deno": "deno task --config packages/iroh-http-deno/deno.jsonc test",
    "test:interop": "bash tests/http-compliance/run.sh",
    "test": "npm run test:rust && npm run test:node && npm run test:deno",
    "release": "bash scripts/release.sh",
    "release:dry": "bash scripts/release.sh --dry-run"
  }
}
