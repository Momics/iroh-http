{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./guest-js"
  },
  "include": ["guest-js/**/*"],
  "exclude": ["node_modules", "dist", "guest-js/__tests__"]
}
