{
  "name": "iroh-http-tauri",
  "version": "0.1.0",
  "description": "Tauri plugin for iroh-http peer-to-peer HTTP",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2",
    "typescript": "^5"
  },
  "dependencies": {
    "iroh-http-shared": "workspace:*"
  }
}
