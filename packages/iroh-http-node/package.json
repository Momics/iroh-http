{
  "name": "iroh-http-node",
  "version": "0.1.0",
  "description": "Node.js native addon for iroh-http (napi-rs)",
  "main": "./index.js",
  "types": "./index.d.ts",
  "napi": {
    "binaryName": "iroh-http-node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "typescript": "^5"
  },
  "dependencies": {
    "iroh-http-shared": "workspace:*"
  }
}
