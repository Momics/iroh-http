{
  "name": "@momics/iroh-http-node",
  "version": "0.3.2",
  "description": "Node.js native addon for iroh-http (napi-rs)",
  "main": "./lib.js",
  "types": "./lib.d.ts",
  "napi": {
    "name": "iroh-http-node",
    "triples": {
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release && tsc",
    "build:debug": "napi build --platform && tsc",
    "build:all": "node scripts/build-all.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node test/e2e.mjs && node test/compliance.mjs",
    "test:e2e": "node test/e2e.mjs",
    "test:compliance": "node test/compliance.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "@types/node": "^25.6.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@momics/iroh-http-shared": "^0.3"
  },
  "optionalDependencies": {
    "@momics/iroh-http-node-darwin-arm64": "0.3.2",
    "@momics/iroh-http-node-darwin-x64": "0.3.2",
    "@momics/iroh-http-node-linux-x64-gnu": "0.3.2",
    "@momics/iroh-http-node-linux-arm64-gnu": "0.3.2",
    "@momics/iroh-http-node-win32-x64-msvc": "0.3.2"
  },
  "files": [
    "*.js",
    "*.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "os": ["darwin", "linux", "win32"],
  "cpu": ["x64", "arm64"],
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Momics/iroh-http"
  },
  "homepage": "https://github.com/Momics/iroh-http"
}
