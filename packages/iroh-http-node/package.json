{
  "name": "@momics/iroh-http-node",
  "version": "0.1.0",
  "description": "Node.js native addon for iroh-http (napi-rs)",
  "main": "./lib.js",
  "types": "./lib.d.ts",
  "napi": {
    "binaryName": "iroh-http-node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "typecheck": "tsc --noEmit",
    "test": "node test/e2e.mjs",
    "test:smoke": "node test/smoke.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "@types/node": "^25.6.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@momics/iroh-http-shared": "*"
  },
  "files": [
    "*.js",
    "*.d.ts",
    "*.node"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT OR Apache-2.0"
}
