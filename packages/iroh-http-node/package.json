{
  "name": "@momics/iroh-http-node",
  "version": "0.1.3",
  "description": "Node.js native addon for iroh-http (napi-rs)",
  "main": "./lib.js",
  "types": "./lib.d.ts",
  "napi": {
    "binaryName": "iroh-http-node",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release && tsc",
    "build:debug": "napi build --platform && tsc",
    "build:all": "node scripts/build-all.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node test/smoke.mjs && node test/e2e.mjs && node test/compliance.mjs",
    "test:smoke": "node test/smoke.mjs",
    "test:e2e": "node test/e2e.mjs",
    "test:compliance": "node test/compliance.mjs",
    "bench": "node bench/throughput.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "@types/node": "^25.6.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@momics/iroh-http-shared": "^0.1.0"
  },
  "files": [
    "*.js",
    "*.d.ts",
    "*.node"
  ],
  "publishConfig": {
    "access": "public"
  },
  "os": ["darwin", "linux", "win32"],
  "cpu": ["x64", "arm64"],
  "license": "MIT OR Apache-2.0"
}
