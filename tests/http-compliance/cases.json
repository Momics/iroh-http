    "request": { "method": "GET", "path": "/status/500", "headers": {}, "body": null },
    "response": { "status": 500 }
  },
  {
    "id": "post-echo-body",
    "description": "POST body is echoed back",
    "request": { "method": "POST", "path": "/echo", "headers": {}, "body": "hello iroh" },
    "response": { "status": 200, "bodyExact": "hello iroh" }
  },
  {
    "id": "patch-with-body",
    "description": "PATCH request body is echoed back",
    "request": { "method": "PATCH", "path": "/echo", "headers": {}, "body": "patch payload" },
    "response": { "status": 200, "bodyExact": "patch payload" }
  },
  {
    "id": "delete-with-body",
    "description": "DELETE request body is echoed back",
    "request": { "method": "DELETE", "path": "/echo", "headers": {}, "body": "delete payload" },
    "response": { "status": 200, "bodyExact": "delete payload" }
  },
  {
    "id": "options-method",
    "description": "OPTIONS method reaches handler and returns 200",
    "request": { "method": "OPTIONS", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "OPTIONS" }
  },
  {
    "id": "options-with-body",
    "description": "OPTIONS request body is forwarded to handler (issue-58: serve body fix)",
    "request": { "method": "OPTIONS", "path": "/echo", "headers": {}, "body": "options body" },
    "response": { "status": 200, "bodyExact": "options body" }
  },
  {
    "id": "custom-verb-method",
    "description": "Custom HTTP verb (SEARCH) reaches handler",
    "request": { "method": "SEARCH", "path": "/echo-method", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "SEARCH" }
  },
  {
    "id": "custom-verb-with-body",
    "description": "Custom verb request body is forwarded to handler (issue-58: serve body fix)",
    "request": { "method": "SEARCH", "path": "/echo", "headers": {}, "body": "custom verb body" },
    "response": { "status": 200, "bodyExact": "custom verb body" }
  },
  {
    "id": "custom-request-header-forwarded",
    "description": "Custom request header arrives at handler",
    "request": {
      "method": "GET",
      "path": "/header/x-test",
      "headers": { "x-test": "ping" },
      "body": null
    },
    "response": { "status": 200, "bodyExact": "ping" }
  },
  {
    "id": "custom-response-header",
    "description": "Handler can set custom response headers",
    "request": { "method": "GET", "path": "/set-header/x-reply/pong", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "x-reply": "pong" } }
  },
  {
    "id": "multiple-response-headers",
    "description": "Multiple custom response headers are all delivered to the client",
    "request": { "method": "GET", "path": "/set-headers/3", "headers": {}, "body": null },
    "response": { "status": 200, "headers": { "x-h-0": "v0", "x-h-1": "v1", "x-h-2": "v2" } }
  },
  {
    "id": "peer-id-present",
    "description": "peer-id header is injected and non-empty",
    "request": { "method": "GET", "path": "/header/peer-id", "headers": {}, "body": null },
    "response": { "status": 200, "bodyNotEmpty": true }
  },
  {
    "id": "peer-id-not-spoofable",
    "description": "Client-supplied peer-id is stripped; the value reflects the real peer identity",
    "request": {
      "method": "GET",
      "path": "/header/peer-id",
      "headers": { "peer-id": "SPOOFED" },
      "body": null
    },
    "response": { "status": 200, "bodyNot": "SPOOFED" }
  },
  {
    "id": "path-preserved",
    "description": "Request path is preserved verbatim at the handler",
