    "response": { "status": 200, "bodyExact": "/echo-path" }
  },
  {
    "id": "path-with-query-string",
    "description": "Query string is preserved and accessible at the handler",
    "request": { "method": "GET", "path": "/echo-query?foo=bar&baz=1", "headers": {}, "body": null },
    "response": { "status": 200, "bodyExact": "?foo=bar&baz=1" }
  },
  {
    "id": "path-with-trailing-slash",
